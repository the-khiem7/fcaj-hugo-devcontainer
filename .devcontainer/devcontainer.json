{
  "name": "Hugo Development",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "HUGO_VERSION": "0.134.3"
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "vscode"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [1313],
  "portsAttributes": {
    "1313": {
      "label": "Hugo Live Preview",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": [
        "content/_index.md",
        ".devcontainer/devcontainer.json"
      ]
    },
    "vscode": {
      "settings": {
        "files.exclude": {
          "**/.hugo_build.lock": true,
          "**/public": true
        }
      },
      "extensions": [
        "budparr.language-hugo-vscode",
        "bungcip.better-toml",
        "ms-vscode.vscode-markdown-preview",
        "davidanson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker",
        "ms-vscode.vscode-json",
        "ms-vscode.vscode-yaml"
      ]
    }
  },
  "updateContentCommand": "bash -lc 'set -euo pipefail; git submodule update --init --recursive'",
  "postCreateCommand": "hugo version",
  "remoteUser": "vscode"
}
